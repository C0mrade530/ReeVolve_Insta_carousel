# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys (CometAPI — OpenAI-совместимый прокси)
OPENAI_API_KEY=sk-your-cometapi-key
OPENAI_BASE_URL=https://api.cometapi.com/v1
OPENAI_MODEL=gpt-4o
NANOBANANA_API_KEY=...

# Security
SECRET_KEY=change-me-to-random-secret
ENCRYPTION_KEY=change-me-to-fernet-key

# Instagram Safety
MIN_DELAY_BETWEEN_POSTS=7200
MAX_DAILY_POSTS=5
SCHEDULE_RANDOMNESS=900

# Storage
MEDIA_STORAGE_PATH=./media
