# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://redis:6379/0

# CometAPI (OpenAI-compatible proxy for Claude)
OPENAI_API_KEY=your-comet-api-key
OPENAI_BASE_URL=https://api.cometapi.com/v1
OPENAI_MODEL=claude-sonnet-4-6
OPENAI_EVAL_MODEL=claude-sonnet-4-6

# Security
SECRET_KEY=change-me-to-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# DEBUG=true allows random encryption key (dev only). Set to false in production.
DEBUG=true

# Instagram Safety
MIN_DELAY_BETWEEN_POSTS=7200
MAX_DAILY_POSTS=5
SCHEDULE_RANDOMNESS=900

# Storage
MEDIA_STORAGE_PATH=./media

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
